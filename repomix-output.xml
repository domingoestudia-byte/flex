  content: ['./app/**/*.{js,jsx}', './components/**/*.{js,jsx}'],
  theme: {
    extend: {
      colors: {
        gold: {
          400: '#D4A843',
          500: '#C9A030',
          600: '#A07820',
        },
      },
    },
  },
}

module.exports = config
```

Estilos globales base:

```css
